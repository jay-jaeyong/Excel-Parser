# ─────────────────────────────────────────────────────────────
# Excel Parser — Environment Configuration
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically by the backend on startup.
# ─────────────────────────────────────────────────────────────

# ── LLM Provider (optional) ───────────────────────────────────
# Set to "openai" or "gemini" to enable AI-based fallback parsing.
# Leave blank to disable (parser will use structural heuristics only).
LLM_PROVIDER=

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Google Gemini ─────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── Parser Tuning ─────────────────────────────────────────────
# Confidence score (0.0–1.0) below which LLM fallback is triggered.
# Lower = more aggressive LLM usage. Default 0.6.
PARSER_CONFIDENCE_THRESHOLD=0.6

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000
